-- Main heartbeat loop
RunService.Heartbeat:Connect(function(dt)
	if not Character or not HRP or not Humanoid then return end

	-- Speed customizer
	if Config.SPEED_CUSTOMIZER_ENABLED then
		Humanoid.WalkSpeed = Config.SPEED
	end

	-- Infinite jump (handled separately via JumpRequest)

	-- Anti ragdoll
	if Config.ANTI_RAGDOLL_ENABLED then
		Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
		Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
	end

	-- No player collision
	if Config.NO_PLAYER_COLLISION_ENABLED then
		for _, part in pairs(Character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CollisionGroup = "NoPlayerCollision"
			end
		end
	end

	-- Medusa range indicator
	if Config.AUTO_MEDUSA_ENABLED then
		local r = Config.AUTO_MEDUSA_RANGE
		MedusaIndicator.Transparency = 0.7
		MedusaIndicator.Size = Vector3.new(0.2, r * 2, r * 2)
		MedusaIndicator.CFrame = CFrame.new(HRP.Position) * CFrame.Angles(0, 0, math.pi / 2)
	else
		MedusaIndicator.Transparency = 1
	end

	-- Spin body
	if Config.SPIN_BODY_ENABLED then
		HRP.CFrame = HRP.CFrame * CFrame.Angles(0, math.rad(Config.SPIN_BODY_SPEED * dt), 0)
	end

	-- Lock target (aimbot orient)
	if Config.LOCK_TARGET_ENABLED and LockTarget and LockTarget.Character then
		local root = LockTarget.Character:FindFirstChild("HumanoidRootPart")
		if root then
			local dir = (root.Position - HRP.Position)
			dir = Vector3.new(dir.X, 0, dir.Z).Unit
			if dir.Magnitude > 0 then
				HRP.CFrame = CFrame.new(HRP.Position, HRP.Position + dir)
			end
		end
	end

	-- Steal timer bar animation (cosmetic)
	if StealTimerFill then
		local t = (tick() % 2) / 2
		StealTimerFill.Size = UDim2.new(t, 0, 1, 0)
	end

	-- Melee aimbot
	if Config.MELEE_AIMBOT_ENABLED then
		local target = LockTarget or getClosestTarget(Config.MELEE_AIMBOT_RANGE)
		if target and target.Character then
			local root = target.Character:FindFirstChild("HumanoidRootPart")
			if root then
				local dist = (HRP.Position - root.Position).Magnitude
				if dist <= Config.MELEE_AIMBOT_RANGE then
					local dir = Vector3.new(root.Position.X - HRP.Position.X, 0, root.Position.Z - HRP.Position.Z).Unit
					if dir.Magnitude > 0 then
						HRP.CFrame = CFrame.new(HRP.Position, HRP.Position + dir)
					end
				end
			end
		end
	end

	-- Auto Medusa (fire remote)
	if Config.AUTO_MEDUSA_ENABLED then
		local target = getClosestTarget(Config.AUTO_MEDUSA_RANGE)
		if target and target.Character then
			-- Fire via CombatService
			pcall(function()
				local re = game:GetService("ReplicatedStorage"):FindFirstChild("Packages")
					and game:GetService("ReplicatedStorage").Packages:FindFirstChild("Net")
				if re then
					local combat = re:FindFirstChild("RE/CombatService/ApplyImpulse", true)
					if combat then
						-- combat:FireServer(target.Character.HumanoidRootPart, Vector3.new(0,50,0))
					end
				end
			end)
		end
	end

	-- Auto TP to steal target
	if Config.AUTO_TP_ENABLED then
		local plot = getPlot()
		if plot then
			local stealHitbox = plot:FindFirstChild("StealHitbox")
			if stealHitbox then
				local mainPart = stealHitbox:FindFirstChildWhichIsA("BasePart") or stealHitbox
				if mainPart:IsA("BasePart") then
					local dist = (HRP.Position - mainPart.Position).Magnitude
					if dist > Config.STEAL_RANGE then
						HRP.CFrame = CFrame.new(mainPart.Position + Vector3.new(0, 3, 0))
					end
				end
			end
		end
	end

	-- Fling nearby players
	if Config.FLING_ENABLED then
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p.Character then
				local root = p.Character:FindFirstChild("HumanoidRootPart")
				if root then
					local dist = (HRP.Position - root.Position).Magnitude
					if dist <= Config.FLING_RANGE then
						root.AssemblyLinearVelocity = Vector3.new(
							math.random(-50, 50), 80, math.random(-50, 50)
						)
					end
				end
			end
		end
	end

	-- No walk animation
	if Config.NO_WALK_ANIMATION_ENABLED then
		for _, track in pairs(Humanoid:GetPlayingAnimationTracks()) do
			if track.Name == "WalkAnim" or track.Name == "RunAnim" then
				track:Stop(0)
			end
		end
	end
end)

