local function serializeUDim2(value)
    return {
        XScale = value.X.Scale,
        XOffset = value.X.Offset,
        YScale = value.Y.Scale,
        YOffset = value.Y.Offset,
    }
end

local function deserializeUDim2(data)
    if type(data) ~= "table" then return nil end
    return UDim2.new(data.XScale or 0, data.XOffset or 0, data.YScale or 0, data.YOffset or 0)
end

getButtonPositions = function()
    return {
        Speed = serializeUDim2(SmallSpeedGUI.Position),
        Unwalk = serializeUDim2(SmallUnwalkGUI.Position),
        ["Spin Bot"] = serializeUDim2(SmallSpinBotGUI.Position),
        ["Inf Jump"] = serializeUDim2(SmallInfJumpGUI.Position),
        ["Float Up"] = serializeUDim2(SmallFloatGUI.Position),
        FOV = serializeUDim2(SmallFOVGUI.Position),
        ["Anti Ragdoll"] = serializeUDim2(SmallAntiRagGUI.Position),
        ["Ragdoll TP"] = serializeUDim2(SmallRagdollTPGUI.Position),
        ["Drop Brainrot"] = serializeUDim2(SmallDropGUI.Position),
        ["TP Down"] = serializeUDim2(SmallTPDownGUI.Position),
        ["TP Up"] = serializeUDim2(SmallTPUpGUI.Position),
    }
end

local function applyButtonPositions(data)
    if type(data) ~= "table" then return end
    local mapping = {
        Speed = SmallSpeedGUI,
        Unwalk = SmallUnwalkGUI,
        ["Spin Bot"] = SmallSpinBotGUI,
        ["Inf Jump"] = SmallInfJumpGUI,
        ["Float Up"] = SmallFloatGUI,
        FOV = SmallFOVGUI,
        ["Anti Ragdoll"] = SmallAntiRagGUI,
        ["Ragdoll TP"] = SmallRagdollTPGUI,
        ["Drop Brainrot"] = SmallDropGUI,
        ["TP Down"] = SmallTPDownGUI,
        ["TP Up"] = SmallTPUpGUI,
    }
    for name, gui in pairs(mapping) do
        if gui and data[name] then
            local position = deserializeUDim2(data[name])
            if position then
                gui.Position = position
            end
        end
    end
end

