local function startUnwalk()
    if not character then return end
    local anim = character:FindFirstChild("Animate")
    if anim then
        savedAnimate = anim:Clone()
        anim.Disabled = true
        task.wait()
        anim:Destroy()
    end
    local h2 = character:FindFirstChildOfClass("Humanoid")
