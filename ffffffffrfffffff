        resizeSmallGUIs(smallGuiWidth, smallGuiHeight)
    end)

    -- ═══════════════════════════════════════════════════════
    -- ✅ SAVE & RESET BUTTONS
    -- ═══════════════════════════════════════════════════════

    local DEFAULT_JUKE = {floatY = 5, tpDelay = 0.35, floatSpeed = 40, btnSize = device == "iPhone" and 38 or 48, leftBtnSize = device == "iPhone" and 55 or 70, smallW = 80, smallH = 20}

    local SaveBtn = Instance.new("TextButton")
    SaveBtn.Size = UDim2.new(0.44, 0, 0, 28)
    SaveBtn.Position = UDim2.new(0.03, 0, 0, 220)
    SaveBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
    SaveBtn.Text = "💾 Save"
    SaveBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    SaveBtn.Font = Enum.Font.GothamBold
    SaveBtn.TextSize = 12
    SaveBtn.Parent = JukeSettings
    SaveBtn.ZIndex = 11
    Instance.new("UICorner", SaveBtn).CornerRadius = UDim.new(0, 8)

    local ResetBtn = Instance.new("TextButton")
    ResetBtn.Size = UDim2.new(0.44, 0, 0, 28)
    ResetBtn.Position = UDim2.new(0.53, 0, 0, 220)
    ResetBtn.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
    ResetBtn.Text = "🔄 Reset"
    ResetBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ResetBtn.Font = Enum.Font.GothamBold
    ResetBtn.TextSize = 12
    ResetBtn.Parent = JukeSettings
    ResetBtn.ZIndex = 11
    Instance.new("UICorner", ResetBtn).CornerRadius = UDim.new(0, 8)

    local SaveStatus = Instance.new("TextLabel")
    SaveStatus.Size = UDim2.new(1, 0, 0, 20)
    SaveStatus.Position = UDim2.new(0, 0, 0, 252)
    SaveStatus.BackgroundTransparency = 1
    SaveStatus.Text = ""
    SaveStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
    SaveStatus.Font = Enum.Font.Gotham
    SaveStatus.TextSize = 11
    SaveStatus.Parent = JukeSettings
    SaveStatus.ZIndex = 11

    SaveBtn.MouseButton1Click:Connect(function()
        ConfigData.jukeFloatY = jukeFloatY
        ConfigData.jukeTPDelay = jukeTPDelay
        ConfigData.jukeFloatSpeed = jukeFloatSpeed
        ConfigData.jukeBtnSize = buttonSize
        ConfigData.leftBtnSize = leftBtnSize
        ConfigData.smallGuiWidth = smallGuiWidth
        ConfigData.smallGuiHeight = smallGuiHeight
        SaveConfig()
        SaveStatus.Text = "✅ Saved!"
        SaveStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
        task.delay(2, function() SaveStatus.Text = "" end)
    end)

    ResetBtn.MouseButton1Click:Connect(function()
        jukeFloatY = DEFAULT_JUKE.floatY
        jukeTPDelay = DEFAULT_JUKE.tpDelay
        jukeFloatSpeed = DEFAULT_JUKE.floatSpeed
        buttonSize = DEFAULT_JUKE.btnSize
        leftBtnSize = DEFAULT_JUKE.leftBtnSize
        smallGuiWidth = DEFAULT_JUKE.smallW
        smallGuiHeight = DEFAULT_JUKE.smallH
        FloatValLabel.Text = tostring(jukeFloatY)
        DelayValLabel.Text = string.format("%.2f", jukeTPDelay)
        SpeedValLabel.Text = tostring(jukeFloatSpeed)
        BtnSizeValLabel.Text = tostring(buttonSize)
        LeftBtnValLabel.Text = tostring(leftBtnSize)
        SmallGuiValLabel.Text = tostring(smallGuiWidth)
        relayoutRightButtons(buttonSize)
        relayoutLeftButtons(leftBtnSize)
        resizeSmallGUIs(smallGuiWidth, smallGuiHeight)
        SaveStatus.Text = "🔄 Reset to defaults!"
        SaveStatus.TextColor3 = Color3.fromRGB(255, 200, 80)
        task.delay(2, function() SaveStatus.Text = "" end)
    end)

    -- Load saved settings if available
    if ConfigData.jukeFloatY then jukeFloatY = ConfigData.jukeFloatY; FloatValLabel.Text = tostring(jukeFloatY) end
    if ConfigData.jukeTPDelay then jukeTPDelay = ConfigData.jukeTPDelay; DelayValLabel.Text = string.format("%.2f", jukeTPDelay) end
    if ConfigData.jukeFloatSpeed then jukeFloatSpeed = ConfigData.jukeFloatSpeed; SpeedValLabel.Text = tostring(jukeFloatSpeed) end
    if ConfigData.jukeBtnSize then buttonSize = ConfigData.jukeBtnSize; BtnSizeValLabel.Text = tostring(buttonSize); relayoutRightButtons(buttonSize) end
    if ConfigData.leftBtnSize then leftBtnSize = ConfigData.leftBtnSize; LeftBtnValLabel.Text = tostring(leftBtnSize); relayoutLeftButtons(leftBtnSize) end
    if ConfigData.smallGuiWidth and ConfigData.smallGuiHeight then
        smallGuiWidth = ConfigData.smallGuiWidth
        smallGuiHeight = ConfigData.smallGuiHeight
        SmallGuiValLabel.Text = tostring(smallGuiWidth)
        resizeSmallGUIs(smallGuiWidth, smallGuiHeight)
    end

    -- Gear opens/closes settings
    JukeGear.MouseButton1Click:Connect(function()
        JukeSettings.Visible = not JukeSettings.Visible
    end)

    -- ═══════════════════════════════════════════════════════
    -- ✅ JUKE LOGIC: Float up, spam tool, wait, then TP down
    -- ═══════════════════════════════════════════════════════

    JukeButton.MouseButton1Click:Connect(function()
        if jukeActive then return end
        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        if not r then return end
        jukeActive = true
        JukeButton.BackgroundColor3 = Color3.fromRGB(138, 43, 226)

        local startPos = r.Position
        local targetY = startPos.Y + jukeFloatY

        -- Float up using velocity + spam tool activate
        local floatConn
        floatConn = RunService.Heartbeat:Connect(function()
            if not jukeActive then if floatConn then floatConn:Disconnect() end return end
            local rr = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not rr then if floatConn then floatConn:Disconnect() end return end

            -- Spam activate held tool
            local char = player.Character
            if char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool then
                    pcall(function() tool:Activate() end)
                end
            end

            if rr.Position.Y >= targetY then
                rr.AssemblyLinearVelocity = Vector3.new(rr.AssemblyLinearVelocity.X, 0, rr.AssemblyLinearVelocity.Z)
                floatConn:Disconnect()
                -- Wait delay then TP down
                task.delay(jukeTPDelay, function()
                    local rrr = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if rrr then
                        rrr.CFrame = CFrame.new(startPos.X, startPos.Y, startPos.Z)
                        rrr.AssemblyLinearVelocity = Vector3.zero
                    end
                    jukeActive = false
                    JukeButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                end)
                return
            end
            rr.AssemblyLinearVelocity = Vector3.new(rr.AssemblyLinearVelocity.X, jukeFloatSpeed, rr.AssemblyLinearVelocity.Z)
        end)
    end)
end

