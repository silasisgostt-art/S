-- ===== AUTO PLAY SYSTEM =====
local function runAutoPlay()
	AutoPlayActive = true
	while Config.AUTO_PLAY_ENABLED and AutoPlayActive do
		local plot = getPlot()
		if plot then
			local podiums = plot:FindFirstChild("AnimalPodiums")
			if podiums then
				local children = podiums:GetChildren()
				-- Cycle through all podiums
				for _, pod in ipairs(children) do
					if not Config.AUTO_PLAY_ENABLED then break end
					local spawn = pod:FindFirstChild("Base") and pod.Base:FindFirstChild("Spawn")
					if spawn and spawn:IsA("BasePart") then
						-- TP to podium
						HRP.CFrame = CFrame.new(spawn.Position + Vector3.new(0, 3, 0))
						task.wait(0.1)

						-- Fire proximity prompt if present
						pcall(function()
							local prompt = spawn:FindFirstChildOfClass("ProximityPrompt")
							if not prompt then
								local att = spawn:FindFirstChild("PromptAttachment")
								if att then prompt = att:FindFirstChildOfClass("ProximityPrompt") end
							end
							if prompt then
								-- fireproximityprompt(prompt)
							end
						end)

						task.wait(AutoPlayDelay > 0 and AutoPlayDelay or 0.5)
					end
				end
			end
		end
		task.wait(1)
	end
	AutoPlayActive = false
end

-- Watch AUTO_PLAY toggle
RunService.Heartbeat:Connect(function()
	if Config.AUTO_PLAY_ENABLED and not AutoPlayActive then
		task.spawn(runAutoPlay)
	end
end)

