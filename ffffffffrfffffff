    local function hAttachESP(player)
        if player == lp2 then return end
        local function apply(character)
            if HubPlayerESP.Highlights[player] then pcall(function() HubPlayerESP.Highlights[player]:Destroy() end) end
            if HubPlayerESP.Billboards[player] then pcall(function() HubPlayerESP.Billboards[player]:Destroy() end) end
            HubPlayerESP.Highlights[player] = hCreateHighlight(character)
            HubPlayerESP.Billboards[player] = hCreateBillboard(character, player)
        end
        if player.Character then apply(player.Character) end
        local conn = player.CharacterAdded:Connect(apply)
        table.insert(HubPlayerESP.Connections, conn)
    end

