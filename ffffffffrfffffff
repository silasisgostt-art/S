local function setFloat(state)
	FloatActive = state
	floatBtn.Text = state and "FLOAT ON" or "FLOAT"
	floatBtn.BackgroundColor3 = state and Color3.fromRGB(50, 180, 100) or Color3.fromRGB(20, 30, 50)

	if state then
		-- Smoothly raise hipheight
		local targetH = Config.FLOAT_HEIGHT
		local step = (targetH - Humanoid.HipHeight) / 20
		for i = 1, 20 do
			task.wait(0.04)
			Humanoid.HipHeight = Humanoid.HipHeight + step
		end
		Humanoid.HipHeight = targetH
	else
		-- Drop back down
		local targetH = 2
		local step = (targetH - Humanoid.HipHeight) / 20
		for i = 1, 20 do
			task.wait(0.04)
			Humanoid.HipHeight = Humanoid.HipHeight + step
		end
		Humanoid.HipHeight = targetH
	end
end

