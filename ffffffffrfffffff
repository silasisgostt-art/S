local function setEnabled(state)
	enabled = state
	local tw     = TweenInfo.new(0.15)
	local goal   = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
	local color  = state and WINE or Color3.fromRGB(60, 10, 20)
	local transp = state and 0 or 1
	TweenService:Create(ToggleKnob, tw, {Position = goal, BackgroundColor3 = state and Color3.new(1,1,1) or RED}):Play()
	TweenService:Create(ToggleBg,   tw, {BackgroundColor3 = color, BackgroundTransparency = transp}):Play()
end

ToggleBtn.MouseButton1Click:Connect(function() setEnabled(not enabled) end)

KeyBtn.MouseButton1Click:Connect(function()
	if listeningForKey then return end
	listeningForKey      = true
	KeyValLbl.Text       = "..."
	KeyValLbl.TextColor3 = Color3.fromRGB(255, 200, 50)
end)

local function setMinimized(state)
	minimized   = state
	MinBtn.Text = state and "+" or "-"
	TweenService:Create(Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = state and UDim2.new(0,GUI_W,0,GUI_MIN) or UDim2.new(0,GUI_W,0,GUI_H)
	}):Play()
end
MinBtn.MouseButton1Click:Connect(function() setMinimized(not minimized) end)

local dragging, dragStart, startPos = false, nil, nil

Frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true; dragStart = input.Position; startPos = Frame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
	or input.UserInputType == Enum.UserInputType.Touch) then
		if minimized then dragging = false; return end
		local d = input.Position - dragStart
		local s = workspace.CurrentCamera.ViewportSize
		Frame.Position = UDim2.new(0,
			math.clamp(startPos.X.Offset + d.X, 0, s.X - GUI_W), 0,
			math.clamp(startPos.Y.Offset + d.Y, 0, s.Y - GUI_H))
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
	if listeningForKey then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			toggleKey            = input.KeyCode
			KeyValLbl.Text       = input.KeyCode.Name
			KeyValLbl.TextColor3 = RED
			listeningForKey      = false
			lastKeybindSet       = tick()
		end
		return
	end
	if input.KeyCode == toggleKey and not gpe and (tick() - lastKeybindSet > 0.3) then
		setEnabled(not enabled)
	end
end)
