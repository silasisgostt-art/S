local PATH_MIN_STOP = 0.60
local PATH_NEXT_POINT_BIAS = 0.45
local PATH_SMOOTH_FACTOR = 0.10
local PATH_CHECKPOINT_RADIUS = 14
local PATH_TP_STEP_DISTANCE = 4.5
local PATH_TP_STEP_DELAY = 0.01

local stealPath1 = {
