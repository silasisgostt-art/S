        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(0.4, 0),
        NumberSequenceKeypoint.new(0.6, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
    WaveGrad.Rotation = 0
    WaveGrad.Parent = WaveStroke

    local pulseSmall = TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
