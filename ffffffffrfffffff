local function makeRow(parent, label, yOff, value, onChange)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Size, lbl.Position = UDim2.new(0.5, 0, 0, 24), UDim2.new(0, 8, 0, yOff)
    lbl.Text, lbl.TextColor3 = label, Color3.new(0.7, 0.7, 0.7)
    lbl.BackgroundTransparency, lbl.Font, lbl.TextSize, lbl.TextXAlignment = 1, Enum.Font.Gotham, 11, Enum.TextXAlignment.Left

    local box = Instance.new("TextBox", parent)
    box.Size, box.Position = UDim2.new(0, 50, 0, 22), UDim2.new(1, -58, 0, yOff + 1)
    box.BackgroundColor3, box.Text, box.TextColor3 = Color3.fromRGB(40, 40, 40), tostring(value), Color3.new(1, 1, 1)
    box.Font, box.TextSize = Enum.Font.Gotham, 12
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v then onChange(v) saveSettings() else box.Text = tostring(value) end
    end)
    return box
end

