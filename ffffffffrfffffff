-- ═══════════════════════════════════════════════════════
local AntiLagModule = {
    Enabled = false,
    Conn = nil,
    CharConns = {}
}

local function cleanCharacterLag(char)
    if not char then return end
    for _, obj in ipairs(char:GetChildren()) do
        if obj:IsA("Accessory") then
            pcall(function() obj:Destroy() end)
        end
        if obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("ShirtGraphic") then
            pcall(function() obj:Destroy() end)
        end
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
            pcall(function() obj:Destroy() end)
        end
    end
end

local function enableAntiLag()
    if AntiLagModule.Enabled then return end
    AntiLagModule.Enabled = true

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            cleanCharacterLag(plr.Character)
        end
        AntiLagModule.CharConns[plr] = plr.CharacterAdded:Connect(function(c)
            if AntiLagModule.Enabled then
                task.wait(0.5)
                cleanCharacterLag(c)
            end
        end)
    end

    AntiLagModule.CharConns["PlayerAdded"] = Players.PlayerAdded:Connect(function(plr)
        AntiLagModule.CharConns[plr] = plr.CharacterAdded:Connect(function(c)
            if AntiLagModule.Enabled then
                task.wait(0.5)
                cleanCharacterLag(c)
            end
        end)
    end)

    AntiLagModule.Conn = RunService.Heartbeat:Connect(function()
        if not AntiLagModule.Enabled then return end
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr.Character then
                cleanCharacterLag(plr.Character)
            end
        end
    end)
end

local function disableAntiLag()
    AntiLagModule.Enabled = false
    if AntiLagModule.Conn then
        AntiLagModule.Conn:Disconnect()
        AntiLagModule.Conn = nil
    end
    for key, conn in pairs(AntiLagModule.CharConns) do
        pcall(function() conn:Disconnect() end)
    end
    AntiLagModule.CharConns = {}
end

