    local function hGetNearestPlayer()
        local char = lp2.Character
        if not char then return nil end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return nil end
        local nearest, nearestDist = nil, HLOCK_RADIUS
        for _, p in pairs(Players2:GetPlayers()) do
            if p ~= lp2 then
                local pc = p.Character
                local phrp = pc and pc:FindFirstChild("HumanoidRootPart")
                if phrp then
                    local d = (phrp.Position - hrp.Position).Magnitude
                    if d <= nearestDist then nearest, nearestDist = pc, d end
                end
            end
        end
        return nearest
    end

    local function hStartSafeFollow()
        if HubSafeFollow.heartbeatConn then HubSafeFollow.heartbeatConn:Disconnect() end
        local char = lp2.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        HubSafeFollow.att = Instance.new("Attachment", hrp)
        HubSafeFollow.lv = Instance.new("LinearVelocity", hrp)
        HubSafeFollow.lv.Attachment0 = HubSafeFollow.att
        HubSafeFollow.lv.MaxForce = 50000
        HubSafeFollow.lv.RelativeTo = Enum.ActuatorRelativeTo.World
        HubSafeFollow.lv.Enabled = false

        HubSafeFollow.gyro = Instance.new("AlignOrientation", hrp)
        HubSafeFollow.gyro.Attachment0 = HubSafeFollow.att
        HubSafeFollow.gyro.MaxTorque = 50000
        HubSafeFollow.gyro.Responsiveness = 120
        HubSafeFollow.gyro.Enabled = false

        HubSafeFollow.heartbeatConn = RunService2.Heartbeat:Connect(function()
            if not HubSafeFollow.Enabled or not HubSafeFollow.Locked then
                HubSafeFollow.lv.Enabled = false
                HubSafeFollow.gyro.Enabled = false
                return
            end
            local character = lp2.Character
            if not character then return end
            local hrp2 = character:FindFirstChild("HumanoidRootPart")
            if not hrp2 then return end
            if not HubSafeFollow.targetChar or not HubSafeFollow.targetChar.Parent then
                HubSafeFollow.targetChar = hGetNearestPlayer()
                return
            end
            local trgHRP = HubSafeFollow.targetChar:FindFirstChild("HumanoidRootPart")
            if not trgHRP then
                HubSafeFollow.targetChar = hGetNearestPlayer()
                return
            end
            HubSafeFollow.lv.Enabled = true
            HubSafeFollow.gyro.Enabled = true
            local frontPos = trgHRP.Position + trgHRP.CFrame.LookVector * 2.2
            local dir = frontPos - hrp2.Position
            if dir.Magnitude > 0.5 then
                HubSafeFollow.lv.VectorVelocity = dir.Unit * HLOCK_SPEED
            else
                HubSafeFollow.lv.VectorVelocity = Vector3.zero
            end
            HubSafeFollow.gyro.CFrame = CFrame.lookAt(hrp2.Position, frontPos)
        end)
    end

