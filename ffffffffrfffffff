-- Apply white half-invisible background and ensure a UIStroke (rainbow outline set by animator)
local function applyWhiteHalfStyle()
    for _, v in pairs(ScreenGui:GetDescendants()) do
        local ok, name = pcall(function() return v.Name end)
        if not ok then name = "" end

        if v:IsA("TextButton") or v:IsA("TextBox") or (v:IsA("Frame") and (name == "MainFrame" or name:match("GUI$") or name:match("^Small"))) or name == "StealBarContainer" then
            pcall(function()
                v.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                v.BackgroundTransparency = 0.5
                if v:IsA("TextBox") then
                    v.TextColor3 = Color3.fromRGB(255, 255, 255)
                end

                -- ensure button/frame strokes are black (overwrite existing strokes)
                local hasStroke = false
                for _, c in pairs(v:GetChildren()) do
                    if c:IsA("UIStroke") then
                        c.Color = Color3.fromRGB(0,0,0)
                        hasStroke = true
                    end
                end
                if not hasStroke then
                    local stroke = Instance.new("UIStroke")
                    stroke.Thickness = 2
                    stroke.Color = Color3.fromRGB(0,0,0)
                    stroke.Parent = v
                end

                -- ensure rounded edges on all boxes
                local hasCorner = false
                for _, c in pairs(v:GetChildren()) do
                    if c:IsA("UICorner") then
                        c.CornerRadius = UDim.new(1, 0)
                        hasCorner = true
                    end
                end
                if not hasCorner then
                    local corner = Instance.new("UICorner")
                    corner.CornerRadius = UDim.new(1, 0)
                    corner.Parent = v
                end

