-- CORRECTED SLIDER FUNCTION (using TextButton track)
-- ============================================================
local function CreateFancySlider(parent, name, minVal, maxVal, defaultVal, callback)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 45)
    frame.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 15)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(200, 160, 190)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 10
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = name .. ": " .. defaultVal

    -- Use a TextButton as the slider track for reliable input
    local track = Instance.new("TextButton", frame)
    track.Size = UDim2.new(1, 0, 0, 6)
    track.Position = UDim2.new(0, 0, 0, 25)
    track.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    track.BackgroundTransparency = 0
    track.Text = ""
    track.AutoButtonColor = false
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(80, 130, 180)
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(0, 0, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
    knob.Text = ""
    knob.AutoButtonColor = false
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function setValueFromPosition(x)
        local relative = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = minVal + relative * (maxVal - minVal)
        if maxVal > 100 then
            val = math.floor(val)
        else
            val = math.floor(val * 10) / 10
        end
        fill.Size = UDim2.new(relative, 0, 1, 0)
        knob.Position = UDim2.new(relative, -7, 0.5, -7)
        label.Text = name .. ": " .. val
        callback(val)
    end

    local dragging = false
    local function startDrag(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            setValueFromPosition(input.Position.X)
        end
    end

    track.InputBegan:Connect(startDrag)
    knob.InputBegan:Connect(startDrag)

    local function updateDrag(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            setValueFromPosition(input.Position.X)
        end
    end

    UserInputService.InputChanged:Connect(updateDrag)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Initial position
    local relative = (defaultVal - minVal) / (maxVal - minVal)
    fill.Size = UDim2.new(relative, 0, 1, 0)
    knob.Position = UDim2.new(relative, -7, 0.5, -7)

    return frame
end

