    -------------------------------------------------------------------------
    -- AUTO GRAB
    -------------------------------------------------------------------------
    local HubAutoGrab = { Enabled = false, Radius = 13, Delay = 0.3, Conn = nil, LastGrab = 0 }

    local function hGetNearestGrabPrompt()
        local char = lp2.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return end
        for _, plot in pairs(plots:GetChildren()) do
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if podiums then
                for _, pod in pairs(podiums:GetChildren()) do
                    local base = pod:FindFirstChild("Base")
                    local spawn = base and base:FindFirstChild("Spawn")
                    if spawn and (spawn.Position - hrp.Position).Magnitude <= HubAutoGrab.Radius then
                        local att = spawn:FindFirstChild("PromptAttachment")
                        if att then
                            for _, obj in pairs(att:GetChildren()) do
                                if obj:IsA("ProximityPrompt") then return obj end
                            end
                        end
                    end
                end
            end
        end
    end

    local function hStartAutoGrab()
        if HubAutoGrab.Conn then HubAutoGrab.Conn:Disconnect() end
        HubAutoGrab.Conn = RunService2.Heartbeat:Connect(function()
            if not HubAutoGrab.Enabled then return end
            if os.clock() - HubAutoGrab.LastGrab < HubAutoGrab.Delay then return end
            local prompt = hGetNearestGrabPrompt()
            if prompt then fireproximityprompt(prompt); HubAutoGrab.LastGrab = os.clock() end
        end)
    end

    local function hStopAutoGrab()
        if HubAutoGrab.Conn then HubAutoGrab.Conn:Disconnect(); HubAutoGrab.Conn = nil end
    end

