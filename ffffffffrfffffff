-- ═══════════════════════════════════════════════════════
-- FEATURE: XRAY BASE
-- ═══════════════════════════════════════════════════════

local XrayBase = { Enabled = false, Original = {}, Conns = {} }

local function isBase(obj)
    if not (obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation")) then return false end
    local n = obj.Name:lower()
    local p = obj.Parent and obj.Parent.Name:lower() or ""
    return n:find("base") or n:find("claim") or p:find("base") or p:find("claim")
end

makeToggle("Xray Base", function(v)
    XrayBase.Enabled = v
    if v then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if isBase(obj) then
                XrayBase.Original[obj] = obj.LocalTransparencyModifier
                obj.LocalTransparencyModifier = 0.8
            end
        end
        XrayBase.Conns[1] = workspace.DescendantAdded:Connect(function(obj)
            if isBase(obj) then
                XrayBase.Original[obj] = obj.LocalTransparencyModifier
                obj.LocalTransparencyModifier = 0.8
            end
        end)
    else
        for _, c in pairs(XrayBase.Conns) do pcall(function() c:Disconnect() end) end
        XrayBase.Conns = {}
        for obj, orig in pairs(XrayBase.Original) do
            pcall(function() obj.LocalTransparencyModifier = orig end)
        end
        XrayBase.Original = {}
    end
end)

-- ═══════════════════════════════════════════════════════
-- FEATURE: NO ANIM
-- ═══════════════════════════════════════════════════════

local NoAnim = { Conns = {} }

makeToggle("No Anim", function(v)
    if v then
        local function block(char)
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            for _, t in pairs(hum:GetPlayingAnimationTracks()) do t:Stop() end
            NoAnim.Conns[char] = hum.AnimationPlayed:Connect(function(t) t:Stop() end)
        end
        if player.Character then block(player.Character) end
        NoAnim.Conns["added"] = player.CharacterAdded:Connect(block)
    else
        for _, c in pairs(NoAnim.Conns) do
            if typeof(c) == "RBXScriptConnection" then c:Disconnect() end
        end
        NoAnim.Conns = {}
    end
end)

-- ═══════════════════════════════════════════════════════
-- FEATURE: PLAYER ESP
-- ═══════════════════════════════════════════════════════

local ESP = { Highlights = {}, Billboards = {}, Conns = {} }
local ESP_COLOR = Color3.fromRGB(85, 170, 255)

local function addESP(plr)
    if plr == player then return end
    local function apply(char)
        if ESP.Highlights[plr] then pcall(function() ESP.Highlights[plr]:Destroy() end) end
        if ESP.Billboards[plr] then pcall(function() ESP.Billboards[plr]:Destroy() end) end

        local h = Instance.new("Highlight")
        h.Adornee = char
        h.FillColor = ESP_COLOR
        h.FillTransparency = 0.25
        h.OutlineColor = ESP_COLOR
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Parent = CoreGui
        ESP.Highlights[plr] = h

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bb = Instance.new("BillboardGui")
            bb.Adornee = hrp
            bb.AlwaysOnTop = true
            bb.Size = UDim2.new(0, 100, 0, 20)
            bb.StudsOffsetWorldSpace = Vector3.new(0, 3, 0)
            bb.MaxDistance = 600
            bb.Parent = CoreGui
            local bg = Instance.new("Frame", bb)
            bg.Size = UDim2.new(1, 0, 1, 0)
            bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            bg.BackgroundTransparency = 0.4
            Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 6)
            local txt = Instance.new("TextLabel", bg)
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Font = Enum.Font.GothamSemibold
            txt.TextSize = 13
            txt.TextColor3 = Color3.new(1, 1, 1)
            txt.TextStrokeTransparency = 0.2
            txt.Text = plr.DisplayName
            ESP.Billboards[plr] = bb
        end
    end
    if plr.Character then apply(plr.Character) end
    table.insert(ESP.Conns, plr.CharacterAdded:Connect(apply))
end

makeToggle("Player ESP", function(v)
    if v then
        for _, p in ipairs(Players:GetPlayers()) do addESP(p) end
        table.insert(ESP.Conns, Players.PlayerAdded:Connect(addESP))
        table.insert(ESP.Conns, Players.PlayerRemoving:Connect(function(p)
            if ESP.Highlights[p] then pcall(function() ESP.Highlights[p]:Destroy() end) ESP.Highlights[p] = nil end
            if ESP.Billboards[p] then pcall(function() ESP.Billboards[p]:Destroy() end) ESP.Billboards[p] = nil end
        end))
    else
        for _, h in pairs(ESP.Highlights) do pcall(function() h:Destroy() end) end
        for _, b in pairs(ESP.Billboards) do pcall(function() b:Destroy() end) end
        for _, c in ipairs(ESP.Conns) do pcall(function() c:Disconnect() end) end
        ESP.Highlights = {}
        ESP.Billboards = {}
        ESP.Conns = {}
    end
end)

