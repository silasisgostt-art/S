-- FEATURE: OPTIMIZER
-- ═══════════════════════════════════════════════════════

local OptimizerOn = false

local function enableOptimizer()
    if OptimizerOn then return end
    OptimizerOn = true
    pcall(function()
        workspace.Terrain.WaterWaveSize = 0
        Lighting.GlobalShadows = false
        Lighting.Brightness = 1
        Lighting.ClockTime = 12
    end)
    for _, obj in pairs(game:GetDescendants()) do
        pcall(function()
            if obj:IsA("BasePart") then
                obj.Material = Enum.Material.Plastic
            elseif obj:IsA("Decal") then
                obj.Transparency = 1
            end
        end)
    end
end

makeToggle("Optimizer", function(v)
    if v then enableOptimizer() end
end)

-- ═══════════════════════════════════════════════════════
-- FEATURE: ANTI BEE & DISCO (Block effect remotes)
-- ═══════════════════════════════════════════════════════

local AntiBee = { Enabled = false, Watcher = nil }
local AntiBeeKeywords = {"effect", "vfx", "fx", "particle", "camera", "shake", "blur", "flash", "visual", "ui", "item"}

local function enableAntiBee()
    if AntiBee.Enabled then return end
    AntiBee.Enabled = true
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    AntiBee.Watcher = ReplicatedStorage.DescendantAdded:Connect(function(r)
        if AntiBee.Enabled and r:IsA("RemoteEvent") then
            for _, k in pairs(AntiBeeKeywords) do
                if r.Name:lower():find(k) then
                    pcall(function()
                        for _, c in pairs(getconnections(r.OnClientEvent)) do
                            if c.Disable then c:Disable() end
                        end
                    end)
                    break
                end
            end
        end
    end)
end

local function disableAntiBee()
    AntiBee.Enabled = false
    if AntiBee.Watcher then AntiBee.Watcher:Disconnect(); AntiBee.Watcher = nil end
end

makeToggle("Anti Bee & Disco", function(v)
    if v then enableAntiBee() else disableAntiBee() end
end)

-- ═══════════════════════════════════════════════════════
-- FEATURE: ANTI LAG (RUNS ALL ANTI-LAG AT ONCE)
-- ═══════════════════════════════════════════════════════

local AntiLag = { Enabled = false, DescConn = nil }

makeToggle("Anti Lag (ALL)", function(v)
    AntiLag.Enabled = v
    if v then
        -- Activate all anti-lag features
        enableFPSDev()
        enableOptimizer()
        enableAntiBee()

        -- Remove particles, trails, effects, lights
        task.spawn(function()
            for _, obj in pairs(workspace:GetDescendants()) do
                pcall(function()
                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam")
                        or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles")
                        or obj:IsA("Explosion") then
                        obj:Destroy()
                    elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
                        obj:Destroy()
                    end
                end)
            end
        end)

        -- Disable shadows, atmosphere, post-processing
        pcall(function()
            Lighting.GlobalShadows = false
            Lighting.FogEnd = 9e9
            if Lighting:FindFirstChild("Atmosphere") then Lighting.Atmosphere:Destroy() end
        end)
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
        pcall(function()
            workspace.Terrain.WaterWaveSize = 0
            workspace.Terrain.WaterReflectance = 0
            workspace.Terrain.WaterTransparency = 0
        end)
        pcall(function()
            for _, e in pairs(workspace.CurrentCamera:GetChildren()) do
                if e:IsA("BloomEffect") or e:IsA("BlurEffect") or e:IsA("DepthOfFieldEffect")
                    or e:IsA("SunRaysEffect") or e:IsA("ColorCorrectionEffect") then
                    e:Destroy()
                end
            end
        end)

        -- Kill new effects as they spawn
        AntiLag.DescConn = workspace.DescendantAdded:Connect(function(obj)
            pcall(function()
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam")
                    or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles")
                    or obj:IsA("Explosion") then
                    obj:Destroy()
                end
            end)
        end)
    else
        disableFPSDev()
        disableAntiBee()
        if AntiLag.DescConn then AntiLag.DescConn:Disconnect(); AntiLag.DescConn = nil end
    end
end)

