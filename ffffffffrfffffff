local function resetCharacter()
    if character and hum then
        hum.Health = 0
    end
end

local function stopAnims(humanoid)
    if humanoid then
        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
            track:Stop()
        end
    end
end

local animConnection = nil

local function setupAntiAnim(humanoid)
    if animConnection then
        animConnection:Disconnect()
        animConnection = nil
    end
    stopAnims(humanoid)
    animConnection = humanoid.AnimationPlayed:Connect(function(track)
        track:Stop()
    end)
end

desyncBtn.Activated:Connect(function()
    desyncActive = not desyncActive
    Config.desyncEnabled = desyncActive
    SaveConfig()
    if desyncActive then
        desyncBtn.Text = "DESYNC: ON"
        desyncBtn.BackgroundColor3 = Color3.fromRGB(0,170,80)
        if raknet and raknet.desync then
            raknet.desync(true)
        end
        resetCharacter()

        task.spawn(function()
            local newChar = player.CharacterAdded:Wait()
            local newHum = newChar:WaitForChild("Humanoid")
            setupAntiAnim(newHum)
        end)
    else
        desyncBtn.Text = "DESYNC: OFF"
        desyncBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        if raknet and raknet.desync then
            raknet.desync(false)
        end
        if animConnection then
            animConnection:Disconnect()
            animConnection = nil
        end
    end
end)


