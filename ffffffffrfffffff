RunService.RenderStepped:Connect(function()
	if not enabled then return end
	local char = LocalPlayer.Character
	if char then
		local root = char:FindFirstChild("HumanoidRootPart")
		local hum  = char:FindFirstChildOfClass("Humanoid")
		if root and hum and hum.MoveDirection.Magnitude > 0 then
			local dir = hum.MoveDirection.Unit
			root.AssemblyLinearVelocity = Vector3.new(
				dir.X * BYPASS_SPEED,
				root.AssemblyLinearVelocity.Y,
				dir.Z * BYPASS_SPEED
			)
		end
	end
	local t = tick()
	while tick() - t < LAG_AMOUNT * 0.1 do end
end)

for _, v in pairs(workspace:GetDescendants()) do
	if v:IsA("Texture") or v:IsA("Decal") then v:Destroy()
	elseif v:IsA("Part") and v.Material ~= Enum.Material.Neon and v.Material ~= Enum.Material.ForceField then
		v.Material = Enum.Material.SmoothPlastic
	end
end

