        local dragging, dragInput, dragStart, startPos
        local function update(input)
            local delta = input.Position - dragStart
            HubSafeFollow.btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end

