local PATH_VELOCITY_SPEED = 59.2
local PATH_SECOND_SPEED = 29.6
local PATH_BASE_STOP = 1.32
local PATH_MIN_STOP = 0.60
local PATH_NEXT_POINT_BIAS = 0.45
local PATH_SMOOTH_FACTOR = 0.10
local PATH_CHECKPOINT_RADIUS = 12
local PATH_TP_STEP_DISTANCE = 2.5
local PATH_TP_STEP_DELAY = 0.05

local stealPath1 = {
