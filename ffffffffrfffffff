-- Rainbow outline: cycles UIStroke colors across the GUI
local function startRainbowOutline()
    task.spawn(function()
        while task.wait(0.05) do
            local hue = (tick() * 0.12) % 1
            local color = Color3.fromHSV(hue, 0.6, 0.75) -- less bright
            for _, v in pairs(ScreenGui:GetDescendants()) do
                if v:IsA("UIStroke") then
                    local p = v.Parent
                    -- skip strokes that belong to buttons or main GUI frames (keep button outlines black)
                    if not (p and (p:IsA("TextButton") or p:IsA("ImageButton") or p.Name == "MainFrame" or tostring(p.Name):match("^Small"))) then
                        v.Color = color
                    end
                end
            end
        end
    end)
