}

local function pathMoveToPoint(hrp, current, nextPoint, speed)
    local currentPos = current.pos or current
    local stopRadius = current.checkpointRadius or PATH_BASE_STOP
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not pathActive then 
            conn:Disconnect()
            hrp.AssemblyLinearVelocity = Vector3.zero 
            return 
        end
        
        local pos = hrp.Position
        local target = Vector3.new(currentPos.X, pos.Y, currentPos.Z)
        local dir = target - pos
        local dist = dir.Magnitude
        
        local stopDist
        if current.checkpointRadius then
            stopDist = stopRadius
        else
            stopDist = math.clamp(PATH_BASE_STOP - dist*0.04, PATH_MIN_STOP, PATH_BASE_STOP)
        end
        
        if dist <= stopDist then 
            conn:Disconnect() 
            hrp.AssemblyLinearVelocity = Vector3.zero 
            return 
        end
        
        local moveDir = dir.Unit
        if nextPoint then
            local nextDir = (Vector3.new(nextPoint.X, pos.Y, nextPoint.Z) - pos).Unit
            moveDir = (moveDir + nextDir * PATH_NEXT_POINT_BIAS).Unit
        end
        
        if lastFlatVel.Magnitude > 0.1 then
            moveDir = (moveDir*(1-PATH_SMOOTH_FACTOR) + lastFlatVel.Unit*PATH_SMOOTH_FACTOR).Unit
        end
        
        local vel = Vector3.new(moveDir.X*speed, hrp.AssemblyLinearVelocity.Y, moveDir.Z*speed)
        hrp.AssemblyLinearVelocity = vel
        lastFlatVel = Vector3.new(vel.X, 0, vel.Z)
    end)
    
    while pathActive and (Vector3.new(hrp.Position.X,0,hrp.Position.Z)-Vector3.new(currentPos.X,0,currentPos.Z)).Magnitude > stopRadius do
        RunService.Heartbeat:Wait()
    end
end

local function runStealPath(path)
    local hrpLocal = (player.Character or player.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")
    local i = 1
    while i <= #path do
        local p = path[i]
        if not pathActive then return end
        -- Instead of teleport, walk to the target position using velocity
        if p.teleportHere then
            local offset = p.teleportOffset or Vector3.zero
            local targetPos = p.pos + offset
            local walkSpeed = 29.0
            local stopDist = PATH_TP_STEP_DISTANCE
            local conn
            conn = RunService.Heartbeat:Connect(function()
                if not pathActive then conn:Disconnect() hrpLocal.AssemblyLinearVelocity = Vector3.zero return end
                local pos = hrpLocal.Position
                local toTarget = targetPos - pos
                local dist = toTarget.Magnitude
                if dist <= stopDist then conn:Disconnect() hrpLocal.AssemblyLinearVelocity = Vector3.zero return end
                local moveDir = toTarget.Unit
                local vel = Vector3.new(moveDir.X*walkSpeed, hrpLocal.AssemblyLinearVelocity.Y, moveDir.Z*walkSpeed)
                hrpLocal.AssemblyLinearVelocity = vel
                lastFlatVel = Vector3.new(vel.X, 0, vel.Z)
            end)
            while pathActive and (hrpLocal.Position - targetPos).Magnitude > stopDist do
                RunService.Heartbeat:Wait()
            end
            hrpLocal.AssemblyLinearVelocity = Vector3.zero
            -- Do not return; continue path
        end
        local speed
        if SpeedBooster.Enabled then
            speed = i > 2 and SpeedBooster.StealSpeed or SpeedBooster.NormalSpeed
        else
            speed = i > 2 and PATH_SECOND_SPEED or PATH_VELOCITY_SPEED
        end
        local nextP = path[i+1] and path[i+1].pos
        -- Ultra-smooth, lag-free, brain-speed bypass
        local currentPos = p.pos or p
        local stopRadius = p.checkpointRadius or PATH_BASE_STOP
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not pathActive then conn:Disconnect() hrpLocal.AssemblyLinearVelocity = Vector3.zero return end
            local pos = hrpLocal.Position
            local target = Vector3.new(currentPos.X, pos.Y, currentPos.Z)
            local dir = target - pos
            local dist = dir.Magnitude
            local stopDist = p.checkpointRadius and stopRadius or math.clamp(PATH_BASE_STOP - dist*0.04, PATH_MIN_STOP, PATH_BASE_STOP)
            if dist <= stopDist then conn:Disconnect() hrpLocal.AssemblyLinearVelocity = Vector3.zero return end
            local moveDir = dir.Unit
            if nextP then
                local nextDir = (Vector3.new(nextP.X, pos.Y, nextP.Z) - pos).Unit
                moveDir = (moveDir + nextDir * PATH_NEXT_POINT_BIAS).Unit
            end
            if lastFlatVel.Magnitude > 0.1 then
                moveDir = (moveDir*(1-PATH_SMOOTH_FACTOR) + lastFlatVel.Unit*PATH_SMOOTH_FACTOR).Unit
            end
            local vel = Vector3.new(moveDir.X*speed, hrpLocal.AssemblyLinearVelocity.Y, moveDir.Z*speed)
            hrpLocal.AssemblyLinearVelocity = vel
            lastFlatVel = Vector3.new(vel.X, 0, vel.Z)
        end)
        while pathActive and (Vector3.new(hrpLocal.Position.X,0,hrpLocal.Position.Z)-Vector3.new(currentPos.X,0,currentPos.Z)).Magnitude > stopRadius do
            RunService.Heartbeat:Wait()
        end
        -- If reached 4th checkpoint, skip to final
        if i == 4 then
            i = #path
        else
            i = i + 1
        end
    end
end

local function startStealPath(path)
    pathActive = true
    task.spawn(function() 
        runStealPath(path)
        pathActive = false
        local hrpLocal = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrpLocal then hrpLocal.AssemblyLinearVelocity = Vector3.zero end
    end)
end

local function stopStealPath()
