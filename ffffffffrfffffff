        if Perf.Conn then Perf.Conn:Disconnect(); Perf.Conn = nil end
    end
end)

-- ═══════════════════════════════════════════════════════
-- FEATURE: ANTI FPS DEVOURER
-- ═══════════════════════════════════════════════════════

local FPSDev = { Enabled = false, Conn = nil }

local function cleanChar(char)
    if not char then return end
    for _, obj in ipairs(char:GetChildren()) do
        if obj:IsA("Accessory") or obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("ShirtGraphic")
            or obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
            pcall(function() obj:Destroy() end)
        end
    end
end

local function enableFPSDev()
    if FPSDev.Enabled then return end
    FPSDev.Enabled = true
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then cleanChar(p.Character) end
    end
    FPSDev.Conn = RunService.Heartbeat:Connect(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then cleanChar(p.Character) end
        end
    end)
end

local function disableFPSDev()
    FPSDev.Enabled = false
    if FPSDev.Conn then FPSDev.Conn:Disconnect(); FPSDev.Conn = nil end
end

makeToggle("Anti FPS Devourer", function(v)
    if v then enableFPSDev() else disableFPSDev() end
end)

