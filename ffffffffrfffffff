local function refreshSmallButtonPositions()
    local visibleFrames = {}
    for _, name in ipairs(SmallButtonOrder) do
        local entry = SmallGUIInstances[name]
        if entry and entry.Frame.Visible then
            table.insert(visibleFrames, entry.Frame)
        end
    end

    local columns = 5
    local buttonHeight = 30
    local rows = 3
    local gapX = 8
    local gapY = 8
    local topPadding = 8
    local sidePadding = 10
    local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280, 720)
    local availableWidth = math.max(400, viewport.X - sidePadding * 2)
    local buttonWidth = math.floor((availableWidth - gapX * (columns - 1)) / columns)
    buttonWidth = math.clamp(buttonWidth, 70, 150)
    local totalWidth = columns * buttonWidth + (columns - 1) * gapX
    local startX = math.max(sidePadding, math.floor((viewport.X - totalWidth) / 2))
    local startY = topPadding

    for index, frame in ipairs(visibleFrames) do
        if index > (rows * columns) then
            frame.Visible = false
            continue
        end

        frame.Size = UDim2.new(0, buttonWidth, 0, buttonHeight)
        local row = math.floor((index - 1) / columns)
        local col = (index - 1) % columns
        frame.Position = UDim2.new(
            0,
            startX + col * (buttonWidth + gapX),
            0,
            startY + row * (buttonHeight + gapY)
        )
        frame.Visible = true
    end
end

