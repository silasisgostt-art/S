    -------------------------------------------------------------------------
    local HubXrayBase = {
        Enabled = false, OriginalTransparency = {}, Connections = {},
        BaseKeywords = {"base", "claim"}
    }

    local function hIsPlayerBase(obj)
        if not (obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation")) then return false end
        local n = obj.Name:lower()
        local p = obj.Parent and obj.Parent.Name:lower() or ""
        for _, keyword in ipairs(HubXrayBase.BaseKeywords) do
            if n:find(keyword) or p:find(keyword) then return true end
        end
        return false
    end

    local function hApplyTransparency(obj)
        if hIsPlayerBase(obj) then
            if not HubXrayBase.OriginalTransparency[obj] then
                HubXrayBase.OriginalTransparency[obj] = obj.LocalTransparencyModifier
            end
            obj.LocalTransparencyModifier = 0.8
        end
    end

    local function hEnableXrayBase()
        if HubXrayBase.Enabled then return end
        HubXrayBase.Enabled = true
        for _, obj in ipairs(Workspace2:GetDescendants()) do hApplyTransparency(obj) end
        HubXrayBase.Connections.descendantAdded = Workspace2.DescendantAdded:Connect(function(obj) hApplyTransparency(obj) end)
        HubXrayBase.Connections.characterAdded = lp2.CharacterAdded:Connect(function()
            task.wait(0.5)
            for _, obj in ipairs(Workspace2:GetDescendants()) do hApplyTransparency(obj) end
        end)
    end

    local function hDisableXrayBase()
        if not HubXrayBase.Enabled then return end
        HubXrayBase.Enabled = false
        for _, conn in pairs(HubXrayBase.Connections) do conn:Disconnect() end
        HubXrayBase.Connections = {}
        for obj, original in pairs(HubXrayBase.OriginalTransparency) do obj.LocalTransparencyModifier = original end
        HubXrayBase.OriginalTransparency = {}
    end

