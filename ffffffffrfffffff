--[[
    UNKNOWN DESYNC (PRO UI EDITION)
]]

repeat task.wait() until game:IsLoaded()

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- CONFIG
local DESYNC_ACTIVE = false
local DESYNC_OFFSET = Vector3.new(0, -500, 0)
local TOGGLE_KEY = Enum.KeyCode.K

local desyncConnection
local char, hum, hrp
local desyncClone

-- CHARACTER
local function getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    local c = LocalPlayer.Character
    return c and c:FindFirstChildOfClass("Humanoid")
end

-- CLONE
local function createDesyncClone()
    if desyncClone then desyncClone:Destroy() end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    desyncClone = Instance.new("Model", workspace)
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Parent == character then
            local clone = part:Clone()
            clone.Color = Color3.fromRGB(0,100,255)
            clone.Material = Enum.Material.Neon
            clone.Transparency = 0.5
            clone.Anchored = true
            clone.CanCollide = false
            clone.Parent = desyncClone
        end
    end
end

local function updateClone()
    if not desyncClone or not hrp then return end
    for _, p in pairs(desyncClone:GetChildren()) do
        if p:IsA("BasePart") then
            local orig = char:FindFirstChild(p.Name)
            if orig then
                p.CFrame = orig.CFrame + DESYNC_OFFSET
            end
        end
    end
end

-- DESYNC
local function startDesync()
    hrp = getHRP()
    hum = getHum()
    if not hrp then return end
    
    createDesyncClone()
    DESYNC_ACTIVE = true
    
    desyncConnection = RunService.Heartbeat:Connect(function()
        if not DESYNC_ACTIVE then return end
        
        updateClone()
        
        local cf = hrp.CFrame
        hrp.CFrame = cf + DESYNC_OFFSET
        task.wait()
        hrp.CFrame = cf
    end)
end

local function stopDesync()
    DESYNC_ACTIVE = false
    if desyncConnection then desyncConnection:Disconnect() end
    if desyncClone then desyncClone:Destroy() end
end

-- GUI
local ScreenGui = Instance.new("ScreenGui", game.CoreGui)

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0,240,0,120)
Main.Position = UDim2.new(0.5,-120,0.5,-60)
Main.BackgroundColor3 = Color3.fromRGB(0,0,0)
Main.Active = true
Main.Draggable = true

Instance.new("UICorner", Main)

-- GLOW
local Stroke = Instance.new("UIStroke", Main)
Stroke.Color = Color3.fromRGB(255,255,255)
Stroke.Thickness = 2

-- Glow animation
task.spawn(function()
    while true do
        TweenService:Create(Stroke, TweenInfo.new(1), {Thickness = 4}):Play()
        task.wait(1)
        TweenService:Create(Stroke, TweenInfo.new(1), {Thickness = 2}):Play()
        task.wait(1)
    end
end)

-- TITLE
local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1,0,0,35)
Title.BackgroundTransparency = 1
Title.Text = "UNKNOWN DESYNC"
Title.TextColor3 = Color3.fromRGB(255,255,255)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 18

-- BUTTON
local ToggleBtn = Instance.new("TextButton", Main)
ToggleBtn.Size = UDim2.new(1,-20,0,50)
ToggleBtn.Position = UDim2.new(0,10,0,50)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)
ToggleBtn.Text = "DESYNC: OFF"
ToggleBtn.TextColor3 = Color3.fromRGB(255,255,255)
ToggleBtn.Font = Enum.Font.GothamBold
ToggleBtn.TextSize = 16

Instance.new("UICorner", ToggleBtn)

local BtnStroke = Instance.new("UIStroke", ToggleBtn)
BtnStroke.Color = Color3.fromRGB(255,255,255)

-- BUTTON ANIMATION
local function animateButton()
    local tween = TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
        Size = UDim2.new(1,-10,0,55)
    })
    tween:Play()
    tween.Completed:Wait()
    
    TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
        Size = UDim2.new(1,-20,0,50)
    }):Play()
end

-- TOGGLE FUNCTION
local function toggleDesync()
    animateButton()
    
    if not DESYNC_ACTIVE then
        startDesync()
        ToggleBtn.Text = "DESYNC: ON"
    else
        stopDesync()
        ToggleBtn.Text = "DESYNC: OFF"
    end
end

ToggleBtn.MouseButton1Click:Connect(toggleDesync)

-- KEYBIND (PRESS K)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == TOGGLE_KEY then
        toggleDesync()
    end
end)

-- CHARACTER
local function setupChar(c)
    char = c
    hum = c:WaitForChild("Humanoid")
    hrp = c:WaitForChild("HumanoidRootPart")
end

if LocalPlayer.Character then setupChar(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(setupChar)
