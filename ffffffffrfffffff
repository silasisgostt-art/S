local function createStyledButton(text, parent)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 32)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Text = text
    btn.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn

    local blackStroke = Instance.new("UIStroke")
    blackStroke.Color = Color3.fromRGB(0, 0, 0)
    blackStroke.Thickness = 4
    blackStroke.Transparency = 0
    blackStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    blackStroke.Parent = btn

    local wave = Instance.new("UIStroke")
    wave.Color = Color3.fromRGB(255, 255, 255)
    wave.Thickness = 2.5
    wave.Transparency = 0.35
    wave.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    wave.ZIndex = 2
    wave.Parent = btn

    local waveGrad = Instance.new("UIGradient")
    waveGrad.Color = ColorSequence.new(Color3.fromRGB(255,255,255))
    waveGrad.Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(0.4, 0), NumberSequenceKeypoint.new(0.6, 0), NumberSequenceKeypoint.new(1, 1) })
    waveGrad.Rotation = 0
    waveGrad.Parent = wave

    TweenService:Create(wave, pulseInfo, {Thickness = 4.2, Transparency = 0.08}):Play()
    RunService.Heartbeat:Connect(function(dt) 
        waveGrad.Rotation = (waveGrad.Rotation + 140 * dt) % 360 
    end)

    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end)

    return btn
end

