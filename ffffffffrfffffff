-- Build content for active tab
local function buildTab(tabName)
	-- Clear scroll
	for _, child in pairs(scrollFrame:GetChildren()) do
		if child:IsA("GuiObject") and child.Name ~= "UIListLayout" and child.Name ~= "UIPadding" then
			child:Destroy()
		end
	end

	local content = tabContent[tabName]
	if not content then return end

	if content.switches then
		for _, data in ipairs(content.switches) do
			makeSwitch(scrollFrame, data.label, data.key, data.order)
		end
	end

	if content.inputs then
		for i, data in ipairs(content.inputs) do
			makeNumberInput(scrollFrame, data.label, data.key, data.default, data.placeholder, 100 + i)
		end
	end

	if content.keybinds then
		for i, name in ipairs(content.keybinds) do
			makeKeybind(scrollFrame, name, 200 + i)
		end
	end

	-- Reset Config button for Settings
	if tabName == "Settings" then
		local resetFrame = Instance.new("Frame")
		resetFrame.Size = UDim2.new(1, 0, 0, 58)
		resetFrame.LayoutOrder = 999
		resetFrame.BackgroundColor3 = Color3.fromRGB(20, 25, 40)
		resetFrame.BorderSizePixel = 0
		resetFrame.Parent = scrollFrame

		Instance.new("UICorner", resetFrame).CornerRadius = UDim.new(0, 8)

		local rstStroke = Instance.new("UIStroke")
		rstStroke.Color = Color3.fromRGB(255, 100, 120)
		rstStroke.Thickness = 1
		rstStroke.Parent = resetFrame

		local rstLbl = Instance.new("TextLabel")
		rstLbl.Size = UDim2.new(1, 0, 1, 0)
		rstLbl.BackgroundTransparency = 1
		rstLbl.Text = "Reset Config"
		rstLbl.TextColor3 = Color3.fromRGB(255, 100, 120)
		rstLbl.TextXAlignment = Enum.TextXAlignment.Center
		rstLbl.TextSize = 16
		rstLbl.Font = Enum.Font.GothamBold
		rstLbl.ZIndex = 5
		rstLbl.Parent = resetFrame

		local rstBtn = Instance.new("TextButton")
		rstBtn.Size = UDim2.new(1, 0, 1, 0)
		rstBtn.BackgroundTransparency = 1
		rstBtn.Text = ""
		rstBtn.ZIndex = 6
		rstBtn.Parent = resetFrame
		rstBtn.MouseButton1Click:Connect(function()
			for k in pairs(Config) do
				if type(Config[k]) == "boolean" then Config[k] = false end
			end
			buildTab(currentTab)
		end)
	end
end

